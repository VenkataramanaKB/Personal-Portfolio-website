---
import Layout from '../layouts/Default.astro';
import { getCollection, render } from 'astro:content';

const entries = await getCollection('now');
const entry = entries[0];
if (!entry) {
	throw new Error('Expected src/content/now/now.md (singleton /now page).');
}

const { Content } = await render(entry);

const updated =
	entry.data.lastUpdated instanceof Date
		? entry.data.lastUpdated.toLocaleString('en-GB', {
				timeZone: 'Asia/Kolkata',
				day: 'numeric',
				month: 'long',
				year: 'numeric',
				hour: 'numeric',
				minute: '2-digit',
				hour12: true,
		  })
		: entry.data.lastUpdated;
---

<Layout title="Now — whencut.in" active="now">
	<div class="prose">
		<h1>Now</h1>
		{updated ? <p class="meta-line -mt-2 mb-8">Last updated · {updated}</p> : null}
		<Content />
	</div>
</Layout>