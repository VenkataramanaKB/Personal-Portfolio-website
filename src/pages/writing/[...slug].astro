---
import Layout from '../../layouts/Default.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('writing', (e) => {
		if (e.id.startsWith('_')) return false;
		if (import.meta.env.PROD && e.data.draft) return false;
		return true;
	});
	return posts.map((post) => ({
		params: { slug: post.id },
	}));
}

const raw = Astro.params.slug;
const id = typeof raw === 'string' ? raw : Array.isArray(raw) ? raw.join('/') : '';

const entry = await getEntry('writing', id);
if (
	!entry ||
	entry.id.startsWith('_') ||
	(import.meta.env.PROD && entry.data.draft)
) {
	return new Response(null, { status: 404 });
}

const { Content } = await render(entry);

function formatPubDate(d: Date): string {
	return d.toLocaleString('en-GB', {
		timeZone: 'Asia/Kolkata',
		day: 'numeric',
		month: 'long',
		year: 'numeric',
		hour: 'numeric',
		minute: '2-digit',
		hour12: true,
	});
}
---

<Layout title={`${entry.data.title} — whencut.in`} active="writing">
	<article class="prose">
		<h1>{entry.data.title}</h1>
		<p class="meta-line mb-8">{formatPubDate(entry.data.pubDate)}</p>
		<Content />
	</article>
</Layout>
